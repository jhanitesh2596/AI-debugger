# GitHub (target repo for investigation)
GITHUB_OWNER=
GITHUB_REPO=
# Required for private repos; recommended for public repos to avoid low rate limits.
# Fine-grained token permissions: Contents read, Metadata read.
GITHUB_TOKEN=
# Optional legacy alias; used if GITHUB_TOKEN is not set.
# GITHUB_OCTOKIT_TOKEN=

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_AUTH_TOKEN=
OLLAMA_MODEL=gpt-oss:20b

# Slack (Socket Mode bot)
SLACK_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=
